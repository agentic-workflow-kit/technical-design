{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReviewSuggestion",
  "type": "object",
  "required": [
    "id",
    "title",
    "severity",
    "lens",
    "dimension",
    "location",
    "evidence",
    "finding",
    "proposed_fix",
    "rationale",
    "gate_ref",
    "lesson_ref",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^S-[0-9]{3}$",
      "description": "S-001, S-002, ..."
    },
    "title": {
      "type": "string",
      "description": "One-line summary"
    },
    "severity": {
      "enum": ["blocking", "recommended", "optional"]
    },
    "lens": {
      "enum": [
        "architecture-enforceability",
        "domain-correctness",
        "agreement-integrity"
      ]
    },
    "dimension": {
      "enum": [
        "source-map",
        "input-resolution",
        "system-model",
        "docs-structure",
        "diagram",
        "approval-status",
        "bounded-context",
        "ubiquitous-language",
        "domain-model",
        "invariant",
        "state-transition",
        "boundary",
        "public-api",
        "consistency",
        "failure",
        "testability",
        "observability",
        "migration-deploy",
        "enforceability",
        "delivery-inputs",
        "over-engineering",
        "under-engineering"
      ]
    },
    "location": {
      "type": "string",
      "description": "Design section, source path, use case, or boundary the finding applies to"
    },
    "evidence": {
      "type": "string",
      "description": "Specific design/source evidence supporting the finding"
    },
    "finding": {
      "type": "string",
      "description": "What is wrong or missing"
    },
    "proposed_fix": {
      "type": "string",
      "description": "Concrete suggested change, not applied automatically"
    },
    "rationale": {
      "type": "string",
      "description": "Why it matters"
    },
    "gate_ref": {
      "type": "string",
      "description": "Rubric, gate, enforcement rule, or standing check that should catch recurrence"
    },
    "lesson_ref": {
      "type": "string",
      "pattern": "^(LSN-[0-9]{3}|none)$",
      "description": "Lessons-ledger id, or none when no lesson applies"
    },
    "effort": {
      "enum": ["S", "M", "L"],
      "description": "Optional rough cost of the fix"
    },
    "status": {
      "enum": ["open", "accepted", "rejected", "deferred"],
      "default": "open"
    },
    "decision_ref": {
      "type": "string",
      "pattern": "^(D-[0-9]{3}|)$",
      "description": "Links to decisions.md once disposed"
    }
  }
}

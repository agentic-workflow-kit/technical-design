        "overlap detection",
        "one active booking for a time slot"
      ]
    },
    {
      "id": "FACT-002",
      "category": "constraint",
      "severity": "critical",
      "source_refs": ["SRC-003"],
      "description": "A resident may hold at most one active booking.",

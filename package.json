{
  "name": "@agentic-workflow-kit/technical-design",
  "version": "0.0.0",
  "description": "Repository tooling for the technical-design skills pack.",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:setup": "bash scripts/dev-setup.sh",
    "worktree:new": "bash scripts/worktree-new.sh",
    "format": "prettier --write \"**/*.{json,js,mjs,ts,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{json,js,mjs,ts,yml,yaml}\"",
    "lint": "pnpm format:check",
    "skills:check": "bash evals/run_static_checks.sh",
    "eval:enforce": "pnpm --filter @agentic-workflow-kit/technical-design-enforce-eval eval",
    "check": "pnpm lint && pnpm skills:check && pnpm eval:enforce"
  },
  "devDependencies": {
    "prettier": "^3.6.2"
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-workflow-kit.local/technical-design/evals/expected-boundaries.schema.json",
  "title": "ExpectedBoundaries",
  "type": "object",
  "required": ["case_id", "contexts"],
  "additionalProperties": false,
  "properties": {
    "case_id": {
      "type": "string",
      "minLength": 1
    },
    "contexts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "source_refs",
          "owns",
          "reads",
          "does_not_own"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^CTX-[0-9]{3}$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "source_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^SRC-[0-9]{3}$"
            }
          },
          "owns": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "reads": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "does_not_own": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "must_include_any": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "must_include_all": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "must_not_include_any": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "accepted_alternatives": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["label", "must_include_all"],
              "additionalProperties": false,
              "properties": {
                "label": {
                  "type": "string",
                  "minLength": 1
                },
                "must_include_all": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "must_not_include_any": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

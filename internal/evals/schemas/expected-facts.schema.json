{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-workflow-kit.local/technical-design/evals/expected-facts.schema.json",
  "title": "ExpectedFacts",
  "type": "object",
  "required": ["case_id", "facts"],
  "additionalProperties": false,
  "properties": {
    "case_id": {
      "type": "string",
      "minLength": 1
    },
    "facts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "category",
          "severity",
          "source_refs",
          "description",
          "must_include_any"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^FACT-[0-9]{3}$"
          },
          "category": {
            "enum": [
              "goal",
              "non-goal",
              "workflow",
              "invariant",
              "api",
              "event",
              "constraint"
            ]
          },
          "severity": {
            "enum": ["critical", "recommended"]
          },
          "source_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^SRC-[0-9]{3}$"
            }
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "must_include_any": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "must_include_all": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "must_not_include_any": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}

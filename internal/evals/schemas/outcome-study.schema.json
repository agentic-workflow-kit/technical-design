{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-workflow-kit.local/technical-design/evals/outcome-study.schema.json",
  "title": "OutcomeStudySummary",
  "type": "object",
  "required": [
    "study_id",
    "source_runs",
    "signals",
    "recurring_defects",
    "promotion_decisions"
  ],
  "additionalProperties": false,
  "properties": {
    "study_id": {
      "type": "string",
      "minLength": 1
    },
    "source_runs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "reference", "redaction_status"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "reference": {
            "type": "string",
            "minLength": 1
          },
          "redaction_status": {
            "enum": ["redacted", "private-raw-local"]
          }
        }
      }
    },
    "signals": {
      "type": "object",
      "required": [
        "planner_clarifications",
        "implementation_blockers",
        "review_findings",
        "rework",
        "test_strategy_gaps"
      ],
      "additionalProperties": false,
      "properties": {
        "planner_clarifications": {
          "type": "integer",
          "minimum": 0
        },
        "implementation_blockers": {
          "type": "integer",
          "minimum": 0
        },
        "review_findings": {
          "type": "integer",
          "minimum": 0
        },
        "rework": {
          "type": "integer",
          "minimum": 0
        },
        "test_strategy_gaps": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "recurring_defects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "evidence_count", "lesson_ref"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^OUT-[0-9]{3}$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "evidence_count": {
            "type": "integer",
            "minimum": 1
          },
          "lesson_ref": {
            "type": "string",
            "pattern": "^(LSN-[0-9]{3}|none)$"
          }
        }
      }
    },
    "promotion_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["defect_id", "decision", "target"],
        "additionalProperties": false,
        "properties": {
          "defect_id": {
            "type": "string",
            "pattern": "^OUT-[0-9]{3}$"
          },
          "decision": {
            "enum": ["promote", "defer", "reject"]
          },
          "target": {
            "enum": [
              "deterministic-fixture",
              "judge-criterion",
              "rubric-update",
              "none"
            ]
          },
          "rationale": {
            "type": "string"
          }
        }
      }
    }
  }
}
